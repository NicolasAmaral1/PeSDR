# Database (VPS: host port 15432 to avoid clash with existing postgres on 5432)
DATABASE_URL=postgresql+asyncpg://ai_sdr_app:ai_sdr_app_dev@localhost:15432/ai_sdr

# Redis (VPS: host port 16379 to avoid clash)
REDIS_URL=redis://localhost:16379/0

# App
APP_ENV=development
LOG_LEVEL=INFO

# Tenants directory (relative to project root)
TENANTS_DIR=tenants

# SOPS age key file (path to private key)
SOPS_AGE_KEY_FILE=/root/.config/sops/age/keys.txt

# LLM API keys — only required for live_llm tests and the simulate CLI demo
# In production these are read from each tenant's secrets.enc.yaml, NOT from .env
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Console session signer (Plano 11). REQUIRED when any tenant has
# `console.enabled: true` in its tenant.yaml. 32+ chars random.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Without this, the HITL operator UI at /console/<slug>/leads will fail.
CONSOLE_SECRET_KEY=

# LangSmith tracing — optional. When LANGCHAIN_TRACING_V2=true and
# LANGSMITH_API_KEY is set, all LLM calls are traced to LangSmith
# automatically (no code change needed). Get an API key at:
#   https://smith.langchain.com → API Keys
#
# Leave these unset to disable tracing entirely (default).
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=pesdr-dev
